int lengthOfLongestSubstring(char* s) {
    int lastSeen[128];

    for(int i = 0; i < 128; i++)
        lastSeen[i] = -1;

    int left = 0;
    int maxLen = 0;

    for(int right = 0; s[right] != '\0'; right++) {

        if(lastSeen[s[right]] >= left) {
            left = lastSeen[s[right]] + 1;
        }

        lastSeen[s[right]] = right;

        int currentLen = right - left + 1;

        if(currentLen > maxLen)
            maxLen = currentLen;
    }

    return maxLen;
}
